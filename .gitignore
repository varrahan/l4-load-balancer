# =============================================================================
# .gitignore - FPGA L4 Load Balancer
# =============================================================================

# ---------------------------------------------------------------------------
# Vivado project files (never commit - regenerated by TCL scripts)
# ---------------------------------------------------------------------------
*.xpr
*.jou
*.log
*.str
*.pb
*.dcp
*.runs/
*.cache/
*.hw/
*.ip_user_files/
*.sim/
vivado_pid*.str
webtalk*.xml
hd_visual/
.Xil/
xsim.dir/
sim_work/

# ---------------------------------------------------------------------------
# Synthesis outputs (large, reproducible)
# ---------------------------------------------------------------------------
synth/reports/
synth/*.bit
synth/*.ltx
synth/*.mcs
synth/*.prm
synth/*.xsa

# ---------------------------------------------------------------------------
# Simulation waveform dumps
# ---------------------------------------------------------------------------
*.vcd
*.ghw
*.wlf
*.fst
transcript
vsim.wlf
modelsim.ini

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# Generated test data (large, regenerated by generate_test_traffic.py)
# ---------------------------------------------------------------------------
tb/pcap_data/*.txt
tb/pcap_data/*.pcap
# Keep the directory itself
!tb/pcap_data/.gitkeep

# ---------------------------------------------------------------------------
# Scapy / Wireshark
# ---------------------------------------------------------------------------
*.pcapng

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace
tags
TAGS